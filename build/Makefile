.PHONY : src/signals/simulator.i

# target to preprocess a source file
src/signals/simulator.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/ccj.dir/build.make CMakeFiles/ccj.dir/src/signals/simulator.cpp.i
.PHONY : src/signals/simulator.cpp.i

src/signals/simulator.s: src/signals/simulator.cpp.s
.PHONY : src/signals/simulator.s

# target to generate assembly for a file
src/signals/simulator.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/ccj.dir/build.make CMakeFiles/ccj.dir/src/signals/simulator.cpp.s
.PHONY : src/signals/simulator.cpp.s

